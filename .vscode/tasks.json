{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "make",
			"type": "shell",
			"command": "make",
			"args": [
				"-j12"
			],
			"group": "build",
			"problemMatcher": [
				"$gcc"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			}
		},
		{
			"label": "build in container",
			"type": "shell",
			"command": "build_container/run_container.sh",
			"args": [
				"make",
				"-j12"
			],
			"group": "build",
			"problemMatcher": [
				"$gcc"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			}
		}
	]
}